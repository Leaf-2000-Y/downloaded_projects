/* 首页样式 */
.container {
  padding: 32rpx;
  min-height: 100vh;
  background: linear-gradient(180deg, #FFF5F5 0%, #F5F5F5 30%);
}

/* Header */
.header {
  text-align: center;
  padding: 60rpx 0 48rpx;
}

.logo {
  width: 128rpx;
  height: 128rpx;
  background: linear-gradient(135deg, #FF2442 0%, #FF6B81 100%);
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 24rpx;
  box-shadow: 0 12rpx 32rpx rgba(255, 36, 66, 0.3);
}

.logo-icon {
  font-size: 64rpx;
}

.title {
  font-size: 44rpx;
  font-weight: 700;
  color: #333;
  display: block;
  margin-bottom: 12rpx;
}

.subtitle {
  font-size: 26rpx;
  color: #999;
  display: block;
}

/* 输入区域 */
.input-section {
  margin-bottom: 32rpx;
}

.input-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.input-wrapper {
  position: relative;
  background: #F8F8F8;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.input-textarea {
  width: 100%;
  min-height: 120rpx;
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
}

.placeholder {
  color: #CCC;
}

.input-actions {
  display: flex;
  justify-content: flex-end;
  margin-top: 16rpx;
}

.action-btn {
  display: flex;
  align-items: center;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
}

.paste-btn {
  background: rgba(255, 36, 66, 0.1);
}

.paste-btn .action-icon,
.paste-btn .action-text {
  color: #FF2442;
  font-size: 24rpx;
}

.clear-btn {
  margin-left: 16rpx;
  background: rgba(0, 0, 0, 0.05);
}

.clear-btn .action-icon {
  color: #999;
  font-size: 24rpx;
}

.action-icon {
  margin-right: 4rpx;
}

.parse-btn {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.loading-spinner {
  width: 32rpx;
  height: 32rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  border-top-color: #fff;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-right: 12rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* 平台区域 */
.platforms-section {
  margin-bottom: 32rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.platforms-scroll {
  white-space: nowrap;
}

.platform-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 32rpx;
  background: #fff;
  border-radius: 16rpx;
  margin-right: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.platform-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.platform-name {
  font-size: 24rpx;
  color: #666;
}

/* 使用说明 */
.tips-section {
  margin-bottom: 32rpx;
}

.tips-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.tips-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.tip-item {
  display: flex;
  align-items: center;
}

.tip-step {
  width: 40rpx;
  height: 40rpx;
  background: linear-gradient(135deg, #FF2442 0%, #FF6B81 100%);
  color: #fff;
  font-size: 24rpx;
  font-weight: 600;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.tip-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
}

/* 历史记录 */
.history-section {
  margin-bottom: 32rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.clear-history {
  font-size: 24rpx;
  color: #999;
}

.history-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.history-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
}

.history-cover {
  width: 120rpx;
  height: 160rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.history-info {
  flex: 1;
  overflow: hidden;
}

.history-title {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: 8rpx;
}

.history-platform {
  font-size: 22rpx;
  color: #999;
  background: #F0F0F0;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  display: inline-block;
}
