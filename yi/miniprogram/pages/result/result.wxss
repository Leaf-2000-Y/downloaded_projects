/* 结果页样式 */
.container {
  padding: 32rpx;
  min-height: 100vh;
  background: #F5F5F5;
}

/* 返回按钮 */
.back-btn {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  margin-bottom: 16rpx;
}

.back-icon {
  font-size: 32rpx;
  color: #333;
  margin-right: 8rpx;
}

.back-text {
  font-size: 28rpx;
  color: #333;
}

/* 视频预览 */
.video-preview {
  padding: 0;
  overflow: hidden;
}

.video-player {
  width: 100%;
  height: 422rpx;
}

/* 视频信息 */
.video-info {
  margin-top: 24rpx;
}

.video-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  line-height: 1.5;
  display: block;
  margin-bottom: 20rpx;
}

.info-row {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 26rpx;
  color: #999;
  width: 120rpx;
}

.info-value {
  font-size: 26rpx;
  color: #333;
  flex: 1;
}

/* 下载进度 */
.download-progress {
  display: flex;
  align-items: center;
  padding: 20rpx 32rpx;
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
}

.progress-bar {
  flex: 1;
  height: 8rpx;
  background: #E0E0E0;
  border-radius: 4rpx;
  overflow: hidden;
  margin-right: 16rpx;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #FF2442 0%, #FF6B81 100%);
  border-radius: 4rpx;
  transition: width 0.3s ease;
}

.progress-text {
  font-size: 24rpx;
  color: #FF2442;
  font-weight: 600;
  min-width: 80rpx;
  text-align: right;
}

/* 操作按钮 */
.action-section {
  margin-bottom: 32rpx;
}

.download-btn {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 图集 */
.image-gallery {
  margin-bottom: 32rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.gallery-scroll {
  white-space: nowrap;
  margin-bottom: 20rpx;
}

.gallery-item {
  display: inline-block;
  width: 240rpx;
  height: 320rpx;
  margin-right: 16rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.gallery-image {
  width: 100%;
  height: 100%;
}

.download-all-btn {
  width: 100%;
  background: #fff;
  color: #FF2442;
  border: 2rpx solid #FF2442;
  border-radius: 48rpx;
  padding: 20rpx 0;
  font-size: 28rpx;
  font-weight: 500;
}

.download-all-btn[disabled] {
  background: #F8F8F8;
  color: #999;
  border-color: #E0E0E0;
}

/* 分享按钮 */
.share-section {
  margin-top: 32rpx;
}

.share-btn {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff;
  color: #333;
  border: 2rpx solid #E0E0E0;
  border-radius: 48rpx;
  padding: 20rpx 0;
  font-size: 28rpx;
}

.share-icon {
  margin-right: 8rpx;
}
