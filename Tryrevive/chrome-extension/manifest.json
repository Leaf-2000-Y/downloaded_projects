{
  "manifest_version": 3,
  "name": "Tryrevive Attention Guard",
  "version": "1.0",
  "description": "夺回你的注意力主权 - 网站使用时间监测与超时冷静插件",
  "permissions": [
    "tabs",
    "storage",
    "notifications",
    "alarms"
  ],
  "host_permissions": [
    "https://api.anthropic.com/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  }
}
